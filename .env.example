# ==============================================
# SmartCart AI - Environment Configuration
# ==============================================
# Copy this file to .env and fill in your actual API keys
# Never commit .env to version control

# REQUIRED: Groq API for AI chat and recommendations
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OPTIONAL: Firebase Configuration
# Setup instructions: https://firebase.google.com/docs/web/setup
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# OPTIONAL: Google Services (for extended features)
# Vision API: https://cloud.google.com/vision/docs/setup
GOOGLE_VISION_API_KEY=your_vision_api_key

# Maps API: https://developers.google.com/maps/documentation/javascript/get-api-key
GOOGLE_MAPS_API_KEY=your_maps_api_key

# Server Configuration
PORT=5000
NODE_ENV=development
